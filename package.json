{
  "name": "moja-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:sync": "npx -y tsx@4.19.2 scripts/sync-i18n.ts",
    "i18n:check": "npx -y tsx@4.19.2 scripts/sync-i18n.ts --ci --scope full",
    "i18n:check:strict": "npx -y tsx@4.19.2 scripts/sync-i18n.ts --ci-strict",
    "i18n:baseline": "npx -y tsx@4.19.2 scripts/sync-i18n.ts --generate-baseline",
    "i18n:baseline:all": "npx -y tsx@4.19.2 scripts/sync-i18n.ts --generate-baseline-all",
    "i18n:post-pr-comment": "npx -y tsx@4.19.2 scripts/post-i18n-comment.ts",
    "verify:dashboard-selection": "npx -y tsx@4.19.2 scripts/verify-dashboard-selection.ts"
    ,
    "docs:worker": "npx -y tsx@4.19.2 scripts/run-document-intelligence-worker.ts --mode worker",
    "docs:requeue-stale": "npx -y tsx@4.19.2 scripts/run-document-intelligence-worker.ts --mode requeue-stale",
    "db:verify": "npx -y tsx@4.19.2 scripts/verify-db-schema.ts",
    "release:check": "npm run db:verify"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.47.1",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "pdf-parse": "^1.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
